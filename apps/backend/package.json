{
  "name": "@camino/backend",
  "version": "0.0.1",
  "description": "Camino - Hono backend API (Node.js + TypeScript)",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -b",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@camino/db": "workspace:*",
    "@camino/shared": "workspace:*",
    "@hono/node-server": "^1.8.0",
    "@hono/zod-validator": "^0.1.11",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.0",
    "hono": "^4.0.0",
    "romcal": "^1.3.0",
    "postgres": "^3.4.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
