{
  "expo": {
    "name": "Camino",
    "slug": "camino",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "requireFullScreen": true,
      "bundleIdentifier": "com.camino.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Local network access for development",
        "NSBonjourServiceTypes": [
          "_expo"
        ]
      }
    },
    "android": {
      "package": "com.camino.app",
      "versionCode": 1,
      "permissions": [],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FAF7ED"
      }
    },
    "plugins": [
      "expo-font",
      [
        "expo-router",
        {
          "origin": false
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "99cc9e5b-7534-40ab-897d-92229d1751d7"
      }
    },
    "scheme": "camino"
  }
}
