{
  "expo": {
    "name": "Camino",
    "slug": "camino",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": true,
      "supportsLandscape": false,
      "requireFullScreen": true,
      "bundleIdentifier": "com.camino.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Local network access for development",
        "NSBonjourServiceTypes": [
          "_expo"
        ]
      }
    },
    "android": {
      "package": "com.camino.app",
      "versionCode": 1,
      "permissions": []
    },
    "plugins": [
      "expo-font",
      [
        "expo-router",
        {
          "origin": false
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {}
    },
    "scheme": "camino",
    "updates": {
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/PROJECT_ID"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
