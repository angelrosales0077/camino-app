# Database (PostgreSQL via Supabase)
DATABASE_URL=postgresql://user:password@host:5432/database_name

# Supabase Auth (optional for backend functionality)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# Mobile public Supabase Auth
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Dev user (temporary until auth is implemented)
DEV_USER_EMAIL=dev@camino.local
DEV_USER_NAME=Dev User

# Redis Cache (Upstash)
REDIS_URL=redis://default:password@host:6379

# Monitoring
SENTRY_DSN=https://key@sentry.io/project

# Payment processing
STRIPE_SECRET_KEY=sk_live_...
MERCADOPAGO_ACCESS_TOKEN=...

# Environment
NODE_ENV=development

# External data providers (optional)
LITURGY_API_BASE=https://calapi.inadiutorium.cz/api/v0/es/calendars/general-es
LITURGY_PROVIDER=romcal
ROMCAL_LOCALE=es
ROMCAL_COUNTRY=argentina
EVANGELIZO_API_BASE=https://feed.evangelizo.org/v2/reader.php
EVANGELIZO_LANG=SP
EVANGELIZO_TYPE=reading
EVANGELIZO_CONTENT=GSP
GOSPEL_API_BASE=https://bible-api.com
GOSPEL_DEFAULT_REF=John 15:1-8
EXTERNAL_TIMEOUT_MS=6000
