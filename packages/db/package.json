{
  "name": "@camino/db",
  "version": "0.0.1",
  "description": "Camino - Drizzle ORM schema and migrations",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./schema": {
      "import": "./dist/schema.js",
      "types": "./dist/schema.d.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "push": "drizzle-kit push:pg --config drizzle.config.ts",
    "studio": "drizzle-kit studio --config drizzle.config.ts",
    "generate": "drizzle-kit generate:pg --config drizzle.config.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.30.0",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.20.0",
    "romcal": "^1.3.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}

